pipeline {
    agent any

     stages {
        stage('Get Code') {
            steps {
                // Obtener código del repo
                git 'https://github.com/cristynalg/helloworld.git'
            }
        }

    stage('Build') {
        steps {
            echo 'Eyyyy, esto es Python. No hay que compilar nada!!!'
	    echo WORKSPACE
	    bat 'dir'
        }
    }

	stage('Debug Path') {
    	steps {
        	bat 'where python'
        	bat 'python --version'
    	}
	}

	stage('Diagnóstico') {
    	steps {
        	bat '''
            	echo El PATH actual es: %PATH%
            	dir "C:\\Users\\Cris\\AppData\\Local\\Python\\pythoncore-3.14-64"
        	'''
    	}
	}

    stage('Tests')
    {
        parallel {

            stage('Unit') {
                steps {
                    catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
                        bat '''
                                set PYTHONPATH=C:\\Users\\Cris\\Desktop\\Tema4_CP_1.1\\helloworld
                                python -m pytest --junitxml=result-unit.xml test\\unit
                        '''
                    }
                }
            }
            
		stage('Rest') {
    		steps {
        		bat '''
                    set PYTHONPATH=%WORKSPACE%
                    set FLASK_APP=app\\api.py
            
                    :: 1. Lanzamos los servicios con /B (Background) para que no bloqueen
                    start /B flask run
                    start /B java -jar C:\\Users\\Cris\\Desktop\\Tema4_CP_1.1\\helloworld\\wiremock-standalone-3.13.2.jar --port 9090 --root-dir test\\wiremock
                    
                    :: 2. ESPERA CRUCIAL: Esperamos 20 segundos a que Java y Flask arranquen de verdad
                    timeout /t 20 /nobreak
                    
                    :: 3. Ahora que el puerto 9090 debería estar abierto, lanzamos los tests
                    python -m pytest --junitxml=result-rest.xml test\\rest
                    
                    :: 4. Limpieza (Opcional): Cerramos los servicios al terminar
                    taskkill /F /IM java.exe /T
                '''
    		}    
		} 
        }
    }
    
    stage ('Results') {
        steps {
            junit 'result*.xml'
        }
    }
  }
}
