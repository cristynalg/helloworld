pipeline {
    agent any

    stages {
        stage('Get Code') {
            steps {
                git 'https://github.com/cristynalg/helloworld.git'
            }
        }

        stage('Build') {
            steps {
                echo "Workspace actual: ${WORKSPACE}"
                bat 'dir'
            }
        }

        stage('Tests') {
            parallel {
                stage('Unit') {
                    steps {
                        catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
                            bat '''
                            bat 'dir'
                                pytest --junitxml=result-unit.xml test\\unit
                            '''
                        }
                    }
                }

                stage('Rest') {
                    steps {
                        bat '''
                            set PYTHONPATH=C:\\Users\\Cris\\AppData\\Local\\Python\\pythoncore-3.14-64
                            set FLASK_APP=app\\api.py
                            set FLASK_ENV=development
                            start flask run                      
                            java -jar C:\\Users\\Cris\\Desktop\\Tema4_CP_1.1\\wiremock-standalone-3.13.2.jar --port 9090 --root-dir test\\wiremock
                            :: Ejecutar tests
                            pytest --junitxml=result-rest.xml test\\rest
                        '''
                    }
                }
            } // Fin de parallel
        } // Fin de stage Tests

        stage('Results') {
            steps {
                junit 'result*.xml'
            }
        }
    } // Fin de stages
} // Fin de pipeline
