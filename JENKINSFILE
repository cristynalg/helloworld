pipeline {
    agent any

     stages {
        stage('Get Code') {
            steps {
                // Obtener código del repo
                git 'https://github.com/cristynalg/helloworld.git'
            }
        }

    stage('Build') {
        steps {
            echo 'Eyyyy, esto es Python. No hay que compilar nada!!!'
	    echo WORKSPACE
	    bat 'dir'
        }
    }

	stage('Debug Path') {
    	steps {
        	bat 'where python'
        	bat 'python --version'
    	}
	}

	stage('Diagnóstico') {
    	steps {
        	bat '''
            	echo El PATH actual es: %PATH%
            	dir "C:\\Users\\Cris\\AppData\\Local\\Python\\pythoncore-3.14-64"
        	'''
    	}
	}

    stage('Tests')
    {
        parallel {

            stage('Unit') {
                steps {
                    catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
                        bat '''
                                set PYTHONPATH=C:\\Users\\Cris\\Desktop\\Tema4_CP_1.1\\helloworld
                                python -m pytest --junitxml=result-unit.xml test\\unit
                        '''
                    }
                }
            }
            
        stage('Rest') {
            steps {
                bat '''
                    set PYTHONPATH=%WORKSPACE%
                    set FLASK_APP=app\\api.py
                    
                    :: 1. Lanzar Flask en segundo plano
                    start /B flask run
                    
                    :: 2. Lanzar Wiremock (asegúrate de que la ruta al .jar es correcta)
                    start /B java -jar "C:\\Users\\Cris\\Desktop\\Tema4_CP_1.1\\helloworld\\wiremock-standalone-3.13.2.jar" --port 9090 --root-dir test\\wiremock
                    
                    :: 3. ESPERA CRUCIAL: Pausamos el script 20 segundos para que el puerto 9090 se abra
                    timeout /t 20 /nobreak
                    
                    :: 4. Verificación técnica (opcional): Esto nos dirá en el log si el puerto está abierto
                    netstat -ano | findstr :9090
                    
                    :: 5. Ejecutar los tests
                    python -m pytest --junitxml=result-rest.xml test\\rest
                    
                    :: 6. Limpieza final: Matamos el proceso de Java para que no bloquee el siguiente build
                    taskkill /F /IM java.exe /T
                '''
            }    
        }
        }
    }
    
    stage ('Results') {
        steps {
            junit 'result*.xml'
        }
    }
  }
}
