//Pipeline para caso practico 1.2 sin nodos (reto 1).
pipeline {
	agent any
    stages {
        stage('Get Code') {
            steps {
                git 'https://github.com/cristynalg/helloworld.git'
            }
        }
		
		//Test unitarios. Ejecuto aqui el test coverage directamente porque ya es una prueba unitaria de por si, y para no usar dos veces el pytest luego en la etapa de cobertura.
		stage('Unit Tests') {
			steps {
				catchError(buildResult: 'UNSTABLE', stageResult: 'SUCCESS') {
					bat '''
						//set PYTHONPATH=%WORKSPACE%
						coverage run --branch --source=app --omit=app\\__init__.py --omit=app\\api.py -m pytest --junitxml=result-unit.xml test\\unit
                       '''
				}
				junit testResults: 'result-unit.xml', allowEmptyResults: true
			}
           }
		
		//Test de integracion. Levanto en 2o plano flask y wiremock y pongo ping de 5 segundos para dar tiempo a levantar servicios antes de ejecutar pytest.
		stage('Rest Tests') {
			steps {
				catchError(buildResult: 'UNSTABLE', stageResult: 'SUCCESS') {
					bat '''
						//set PYTHONPATH=%WORKSPACE%
						set FLASK_APP=app\\api.py
						
						start /B flask run
						//start /B java -jar C:\\Users\\Cris\\Desktop\\Tema4y6\\wiremock-standalone-3.13.2.jar --port 9090 --root-dir test\\wiremock
						start /B java -jar wiremock-standalone-3.13.2.jar --port 9090 --root-dir test\\wiremock
						ping 127.0.0.1 -n 5 >nul
						
						pytest --junitxml=result-rest.xml test\\rest
					'''
				}
				junit testResults: 'result-rest.xml', allowEmptyResults: true
			}
		}
				
		//Test de analisis de codigo estatico. 
		stage('Static Tests') {
			steps {
				catchError(buildResult: 'UNSTABLE', stageResult: 'SUCCESS') {
					bat '''
						set FLASK_APP=app\\api.py
						flake8 --exit-zero --format=pylint app > flake8.out
					'''
				recordIssues qualityGates: [[integerThreshold: 8, threshold: 8.0, type: 'TOTAL'], [criticality: 'FAILURE', integerThreshold: 10, threshold: 10.0, type: 'TOTAL']], sourceCodeRetention: 'LAST_BUILD', tools: [flake8(pattern: 'flake8.out')]
				}
			}
		}

		//Test de seguridad.
		stage('Security Tests') {
			steps {
				catchError(buildResult: 'UNSTABLE', stageResult: 'SUCCESS') {
				bat '''
					bandit --exit-zero -r . -f custom -o bandit.out --msg-template "{abspath}:{line}:{severity}:{test_id}:{msg}"
				'''
				recordIssues qualityGates: [[integerThreshold: 2, threshold: 2.0, type: 'TOTAL'], [criticality: 'FAILURE', integerThreshold: 4, threshold: 4.0, type: 'TOTAL']], sourceCodeRetention: 'LAST_BUILD', tools: [pyLint(pattern: 'bandit.out')]
				}
			}
		}		
		
		//Test de rendimiento.
		stage('Perfomance Tests') {
			steps {
				catchError(buildResult: 'UNSTABLE', stageResult: 'SUCCESS') {
					bat '''
						//C:\\Users\\Cris\\Desktop\\Tema4y6\\apache-jmeter-5.5\\bin\\jmeter -n -t test\\jmeter\\test-plain.jmx -l test-plain.jtl
						apache-jmeter-5.5\\bin\\jmeter -n -t test\\jmeter\\test-plain.jmx -l test-plain.jtl
					'''
				}
				perfReport sourceDataFiles: 'test-plain.jtl'
			}
		}		
		
		//Test de cobertura. Esta etapa solo se encarga de procesar los datos en formato xml obtenidos en la etapa de test unit.
		stage('Coverage Tests') {
			steps {
				catchError(buildResult: 'UNSTABLE', stageResult: 'SUCCESS') {
					bat '''
						coverage xml
					'''
				recordCoverage qualityGates: [[criticality: 'UNSTABLE', integerThreshold: 95, metric: 'LINE', threshold: 95.0], [criticality: 'FAILURE', integerThreshold: 85, metric: 'LINE', threshold: 85.0], [criticality: 'UNSTABLE', integerThreshold: 90, metric: 'BRANCH', threshold: 90.0], [criticality: 'FAILURE', integerThreshold: 80, metric: 'BRANCH', threshold: 80.0] ], tools: [[parser: 'COBERTURA', pattern: 'coverage.xml']]
				}
			}
		}	
	}
}