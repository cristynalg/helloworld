pipeline {
    agent any

     stages {
        stage('Get Code') {
            steps {
                // Obtener código del repo
                git 'https://github.com/cristynalg/helloworld.git'
            }
        }

    stage('Build') {
        steps {
            echo 'Eyyyy, esto es Python. No hay que compilar nada!!!'
	    echo WORKSPACE
	    bat 'dir'
        }
    }

	stage('Debug Path') {
    	steps {
        	bat 'where python'
        	bat 'python --version'
    	}
	}

	stage('Diagnóstico') {
    	steps {
        	bat '''
            	echo El PATH actual es: %PATH%
            	dir "C:\\Users\\Cris\\AppData\\Local\\Python\\pythoncore-3.14-64"
        	'''
    	}
	}

    stage('Tests')
    {
        parallel {

            stage('Unit') {
                steps {
                    catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
                        bat '''
                                set PYTHONPATH=C:\\Users\\Cris\\Desktop\\Tema4_CP_1.1\\helloworld
                                python -m pytest --junitxml=result-unit.xml test\\unit
                        '''
                    }
                }
            }
            
		stage('Rest') {
    		steps {
        		bat '''
            	set PYTHONPATH=%WORKSPACE%
            	set FLASK_APP=app\\api.py
            
            	:: 1. Lanzar Flask en segundo plano (sin start si es posible, o con /B)
            	start /B flask run
            
            	:: 2. Lanzar Wiremock en segundo plano
            	start /B java -jar C:\\Users\\Cris\\Desktop\\Tema4_CP_1.1\\helloworld\\wiremock-standalone-3.13.2.jar --port 9090 --root-dir test\\wiremock
            
            	:: 3. ¡CRUCIAL! Esperar unos segundos a que los servidores despierten
            	timeout /t 10 /nobreak
            
            	:: 4. Ejecutar los tests
            	python -m pytest --junitxml=result-rest.xml test\\rest
            
            	:: 5. (Opcional) Intentar matar los procesos al terminar para no dejar puertos ocupados
            	taskkill /IM java.exe /F
            	taskkill /IM flask.exe /F
        	'''
    		}    
		} 
        }
    }
    
    stage ('Results') {
        steps {
            junit 'result*.xml'
        }
    }
  }
}
